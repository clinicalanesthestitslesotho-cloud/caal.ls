<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Clinical Anaesthetists Association of Lesotho</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f4f8fc;
}

/* HEADER */
header {
    background: linear-gradient(to right, #0b3d91, #1e5bb8);
    color: white;
    text-align: center;
    padding: 30px;
}

header img {
    width: 120px;
}

/* NAV */
nav {
    display: flex;
    justify-content: center;
    background: #0b3d91;
    flex-wrap: wrap;
}

nav a {
    color: white;
    padding: 14px 18px;
    text-decoration: none;
    cursor: pointer;
}

nav a:hover {
    background: #163f7a;
}

/* HERO */
.hero {
    background: url('https://via.placeholder.com/1200x400') center/cover;
    color: white;
    padding: 80px 20px;
    text-align: center;
}

/* SECTION */
.section {
    display: none;
    padding: 30px;
    max-width: 1000px;
    margin: auto;
}

.active {
    display: block;
}

/* CARD */
.card {
    background: white;
    padding: 20px;
    margin: 15px 0;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

/* FORM */
form {
    background: white;
    padding: 20px;
    border-radius: 8px;
}

input, textarea {
    width: 100%;
    padding: 10px;
    margin: 10px 0;
}

button {
    background: #0b3d91;
    color: white;
    border: none;
    padding: 12px;
    cursor: pointer;
}

button:hover {
    background: #163f7a;
}

/* FOOTER */
footer {
    background: #0b3d91;
    color: white;
    text-align: center;
    padding: 15px;
    margin-top: 30px;
}
</style>

<script>
function showSection(id) {
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    document.getElementById(id).classList.add('active');
}
</script>

</head>

<body>

<header>
    <!-- LOGO -->
    <img src="your-logo.jpg" alt="Logo">
    <h1>Clinical Anaesthetists Association of Lesotho</h1>
    <p>Safe Anaesthesia • Professional Excellence • Collaboration</p>
</header>

<nav>
    <a onclick="showSection('home')">Home</a>
    <a onclick="showSection('about')">About</a>
    <a onclick="showSection('education')">Education</a>
    <a onclick="showSection('leadership')">Leadership</a>
    <a onclick="showSection('membership')">Membership</a>
    <a onclick="showSection('contact')">Contact</a>
</nav>

<div class="hero">
    <h2>Safe, Equitable, High-Quality Anaesthesia Care</h2>
</div>

<!-- HOME -->
<div id="home" class="section active">
    <div class="card">
        <h2>Welcome</h2>
        <p>
        The Clinical Anaesthetists Association of Lesotho is a professional body established under the Societies Act No. 20 of 1966, dedicated to advancing safe anaesthesia practice nationwide.
        </p>
    </div>

    <div class="card">
        <h2>Vision</h2>
        <p>
        To ensure safe, equitable, and high-quality anaesthesia care for all through professional excellence and collaboration.
        </p>
    </div>

    <div class="card">
        <h2>Mission</h2>
        <p>
        To ensure high-quality, holistic anaesthetic practice without discrimination and promote the welfare of anaesthetists across the country.
        </p>
    </div>

    <div class="card">
        <h2>Latest Updates</h2>
        <p>• National training workshops ongoing</p>
        <p>• Strengthening international partnerships</p>
    </div>
</div>

<!-- ABOUT -->
<div id="about" class="section">
    <h2>About Us</h2>

    <div class="card">
        <h3>Legal Status</h3>
        <p>
        The Association is established under the Societies Act No. 20 of 1966 and operates as a legal entity with power to sue and be sued.
        </p>
    </div>

    <div class="card">
        <h3>Objectives</h3>
        <ul>
            <li>Develop scope of anaesthetic practice</li>
            <li>Organize refresher courses and training</li>
            <li>Promote ethical and professional standards</li>
            <li>Support members professionally</li>
            <li>Expand anaesthesia services nationwide</li>
            <li>Encourage research and development</li>
            <li>Collaborate with local and international organizations</li>
        </ul>
    </div>

    <div class="card">
        <h3>Funding</h3>
        <p>
        Funded through member subscriptions, donations, and fundraising activities.
        </p>
    </div>
</div>

<!-- EDUCATION -->
<div id="education" class="section">
    <h2>Education</h2>

    <div class="card">Refresher courses for anaesthetists</div>
    <div class="card">Continuous professional development</div>
    <div class="card">Research and training programs</div>
    <div class="card">Guidelines aligned with international standards</div>
</div>

<!-- LEADERSHIP -->
<div id="leadership" class="section">
    <h2>Executive Committee</h2>

    <div class="card">
        <strong>President:</strong> Tebatso Nkoko
    </div>

    <div class="card">
        <strong>Secretary:</strong> Thato Lerotholi
    </div>
</div>

<!-- MEMBERSHIP -->
<div id="membership" class="section">
    <h2>Membership</h2>

    <div class="card">
        <h3>Eligibility</h3>
        <p>
        Open to all clinical practitioners with anaesthetic qualifications registered with recognized health councils in Lesotho.
        </p>
    </div>

    <div class="card">
        <h3>How to Join</h3>
        <p>Submit application → Approval → Pay subscription fee</p>
    </div>

    <div class="card">
        <h3>Benefits</h3>
        <ul>
            <li>Professional networking</li>
            <li>Training opportunities</li>
            <li>Representation in health sector</li>
            <li>Career development</li>
        </ul>
    </div>
</div>

<!-- CONTACT -->
<div id="contact" class="section">
    <h2>Contact Us</h2>

    <div class="card">
        <p><strong>Address:</strong> Ministry of Health Headquarters, 3rd Floor</p>
        <p><strong>Postal:</strong> P.O. Box 9189, Maseru 100</p>
        <p><strong>Email:</strong> clinicalanaesthetists@gmail.com</p>
    </div>

    <form action="http://localhost:3000/contact" method="POST">
        <input name="name" placeholder="Name" required>
        <input name="surname" placeholder="Surname" required>
        <input name="email" type="email" placeholder="Email" required>
        <textarea name="message" placeholder="Message" required></textarea>
        <button type="submit">Send Message</button>
    </form>
</div>

<footer>
    © 2026 Clinical Anaesthetists Association of Lesotho
</footer>

</body>
</html>
